# ============================================================
# Interview Assistant — Variáveis de Ambiente
# Autor: Lucas Melo
# Copie este arquivo para .env e preencha com suas chaves
# NUNCA compartilhe o arquivo .env — ele está no .gitignore
# ============================================================

# Anthropic API Key — obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sua_chave_aqui

# OpenAI API Key (Whisper) — obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sua_chave_openai_aqui

# PostgreSQL — configure com suas credenciais locais
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_aqui
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=NomeDoBancoDeDados

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
